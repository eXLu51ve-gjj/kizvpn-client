<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

           <!-- Network permissions -->
           <uses-permission android:name="android.permission.INTERNET" />
           <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
           <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
           
           <!-- VPN permissions -->
           <uses-permission android:name="android.permission.BIND_VPN_SERVICE" />
           
           <!-- Foreground service permission (required for Android 14+) -->
           <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
           <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
           
           <!-- Camera for QR code scanning -->
           <uses-permission android:name="android.permission.CAMERA" />
           <uses-feature android:name="android.hardware.camera" android:required="false" />
           <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />
           
           <!-- Permission for executing binaries (if needed) -->
           <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
           
           <!-- Notification permission (required for Android 13+) -->
           <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
           
           <!-- Quick Settings Tile permission -->
           <uses-permission android:name="android.permission.BIND_QUICK_SETTINGS_TILE" />
           
           <!-- Permission to query all packages (required for Android 11+ to get installed apps list) -->
           <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

    <application
        android:name=".KizVpnApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.KizVpn"
        android:usesCleartextTraffic="true"
        android:requestLegacyExternalStorage="true"
        tools:targetApi="29">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.KizVpn"
            android:windowSoftInputMode="adjustResize"
            android:screenOrientation="portrait"
            android:launchMode="singleTop">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            
            <!-- ОСНОВНОЙ intent filter для Deep Links (без autoVerify) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" 
                      android:host="host.kizvpn.ru" />
            </intent-filter>
            
            <!-- Поддержка subscription путей -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" 
                      android:host="host.kizvpn.ru"
                      android:pathPrefix="/sub" />
            </intent-filter>
            
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" 
                      android:host="host.kizvpn.ru"
                      android:pathPrefix="/subscription" />
            </intent-filter>
            
            <!-- Поддержка config путей -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" 
                      android:host="host.kizvpn.ru"
                      android:pathPrefix="/config" />
            </intent-filter>
            
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" 
                      android:host="host.kizvpn.ru"
                      android:pathPrefix="/vpn" />
            </intent-filter>
            
            <!-- Поддержка server путей -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" 
                      android:host="host.kizvpn.ru"
                      android:pathPrefix="/server" />
            </intent-filter>
            
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" 
                      android:host="host.kizvpn.ru"
                      android:pathPrefix="/connect" />
            </intent-filter>
            
            <!-- Дополнительные пути для VPN -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" 
                      android:host="host.kizvpn.ru"
                      android:pathPrefix="/plans" />
            </intent-filter>
            
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" 
                      android:host="host.kizvpn.ru"
                      android:pathPrefix="/pricing" />
            </intent-filter>
            
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" 
                      android:host="host.kizvpn.ru"
                      android:pathPrefix="/buy" />
            </intent-filter>
            
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" 
                      android:host="host.kizvpn.ru"
                      android:pathPrefix="/purchase" />
            </intent-filter>
            
            <!-- Дополнительный домен kizvpn.ru -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" 
                      android:host="kizvpn.ru" />
            </intent-filter>
            
            <!-- Поддержка поддоменов для VPN -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" 
                      android:host="vpn.kizvpn.ru" />
            </intent-filter>
            
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" 
                      android:host="api.kizvpn.ru" />
            </intent-filter>
            
            <!-- HTTP версия для совместимости -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="http" 
                      android:host="host.kizvpn.ru" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="kizvpn" />
            </intent-filter>
            
            <!-- Deep link для vless:// схемы -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="vless" />
            </intent-filter>
            
            <!-- Deep link для vmess:// схемы -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="vmess" />
            </intent-filter>
            
            <!-- Deep link для ss:// схемы (Shadowsocks) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="ss" />
            </intent-filter>
            
            <!-- Deep link для trojan:// схемы -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="trojan" />
            </intent-filter>
        </activity>
        
        <!-- Onboarding Activity для первого запуска -->
        <activity
            android:name=".ui.onboarding.OnboardingActivity"
            android:exported="false"
            android:theme="@style/Theme.KizVpn"
            android:screenOrientation="portrait"
            android:launchMode="singleTop" />
        
        <!-- VPN Service (старый) -->
        <service
            android:name=".vpn.VpnService"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:exported="false"
            android:enabled="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="VPN" />
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>
        
        <!-- Новый упрощенный VPN Service -->
        <service
            android:name=".vpn.KizVpnService"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:exported="false"
            android:enabled="true"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="VPN" />
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>
        
        <!-- Quick Settings Tile для быстрого включения/выключения VPN -->
        <service
            android:name=".vpn.KizVpnTileService"
            android:exported="true"
            android:icon="@drawable/kiz_vpn_mono"
            android:label="KIZ VPN"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>
        
    </application>
</manifest>

